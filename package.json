{
  "name": "nas-rag-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:web\"",
    "build": "tsc -p server/tsconfig.json && vite build",
    "start": "node dist-server/index.js",
    "eval:recall": "tsx scripts/eval-recall.ts",
    "smoke": "tsx scripts/smoke-flow.ts",
    "verify": "tsx scripts/multi-verify.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "fuse.js": "^7.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.544.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^10.0.0",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  }
}
