OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# 对话模型输入 token 上限（用于压缩 RAG 片段，避免 400 exceeded model token limit）
CHAT_MODEL_MAX_INPUT_TOKENS=8192
# 会话记忆窗口：每轮问答时最多回看多少轮历史（0 表示关闭历史注入）
CHAT_MAX_HISTORY_TURNS=6
# 预留给指令、问题与安全余量的 token 粗估值（勿过小）
CHAT_PROMPT_SAFETY_TOKENS=384
# 每条检索片段送入模型的最大字符数（默认 1400）
CHAT_RAG_CHUNK_CHARS=1400
# 在剩余 token 预算下，上下文总字符 = 预算 token × 该系数（略小于 1.5 更稳，仍超限时再调小）
CHAT_RAG_CHAR_SLACK=1.2
# 单次对话检索条数（未开 Map-Reduce 时）
CHAT_SEARCH_TOP_K=10
# Map-Reduce：多批检索→各批要点→再带少量原文作答（多轮模型调用；适合 8k 等短上下文）
CHAT_MAP_REDUCE=false
CHAT_MAP_RETRIEVAL_TOP=28
CHAT_MAP_BATCH_SIZE=6
CHAT_MAP_BATCH_MAX_CHARS=9000
CHAT_MAP_CHUNK_CHARS=1600
CHAT_MAP_DIGEST_MAX_CHARS=8000
CHAT_FINAL_EVIDENCE_CHUNKS=5
# 检索结果去重：同一文件最多返回多少个 chunk（提高文件覆盖率）
SEARCH_MAX_CHUNKS_PER_FILE=2
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 百炼多模态向量（走 DashScope multimodal-embedding）：例如 tongyi-embedding-vision-flash-2026-03-06
EMBEDDING_PROVIDER=auto
ENABLE_VECTOR_SEARCH=true
# 扫描时为每个 chunk 请求 embedding 的并发数（默认 4，过大易触发 API 限流）
EMBED_CONCURRENCY=4
ENABLE_OCR=true
# OCR_PROVIDER: tesseract | http | off（设了 OCR_HTTP_URL 且未写 OCR_PROVIDER 时默认走 http）
OCR_PROVIDER=tesseract
# 仅 ASCII（如 chi_sim+eng）；非 ASCII 会被忽略，避免系统里错误的 OCR_LANG 变成乱码语言包名
OCR_LANG=chi_sim+eng
OCR_LANG_PATH=https://tessdata.projectnaptha.com/4.0.0
# 企业推荐：自建 OCR 网关（POST JSON，见 README）
# 使用仓库内 paddle-ocr-bridge 时示例：http://127.0.0.1:8890/ocr
OCR_HTTP_URL=
OCR_HTTP_TOKEN=
ENABLE_PDF_OCR=true
PDF_OCR_ALWAYS=false
PDF_OCR_MAX_PAGES=5
# 超过该大小(MB)的 PDF 不做逐页渲染 OCR，批量扫大 PDF 时可减轻 pdf.js/Tesseract 压力
PDF_OCR_MAX_FILE_MB=12
# MinerU：仅当 MINERU_ENABLED=true 时才会调用；否则永不执行（与是否安装 mineru 无关）。对 PDF/PPTX 优先抽 Markdown，失败则回退内置解析。
MINERU_ENABLED=false
MINERU_CLI=mineru
# 本地常驻 mineru-api 时填写，例如 http://127.0.0.1:8000（见 MinerU 文档 --api-url）
MINERU_API_URL=
MINERU_METHOD=auto
# MINERU_BACKEND=hybrid-auto-engine
# MINERU_LANG=ch
MINERU_TIMEOUT_MS=600000
# 出处/检索缩略图：单张图片最大 MB（GET /api/fs/image）
FS_IMAGE_MAX_MB=20
PORT=8787
# 飞书机器人（Webhook）：事件订阅选「将事件发送至开发者服务器」，请求 URL 填 https://你的公网域名/api/feishu/webhook
# 订阅「接收消息 v2.0」im.message.receive_v1；开启机器人能力；按需申请单聊/群聊消息权限
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 开发者后台「事件与回调」中的 Verification Token（强烈建议配置并与此处一致）
FEISHU_VERIFICATION_TOKEN=
# 若后台配置了 Encrypt Key，则把同一密钥填在此处（用于解密推送体）
FEISHU_ENCRYPT_KEY=
# 海外租户可设 https://open.larksuite.com
# FEISHU_API_BASE=https://open.feishu.cn
# 机器人单条回复最大字符（默认 12000）
# FEISHU_REPLY_MAX_CHARS=12000
# 若服务监听在非本机或 Docker 网络，可显式指定（默认 http://127.0.0.1:${PORT}，用于 Webhook 内调 /api/chat）
# INTERNAL_API_BASE_URL=http://127.0.0.1:8787